<!-- app/views/psychologist_match_chunks/_form.html.erb -->
<%= form_with model: [@profile, @chunk], local: true do |f| %>
  <div>
    <%= f.label :content %><br>
    <%= f.text_area :content, rows: 4 %>
  </div>

  <div>
    <%= f.label :category %><br>
    <%= f.text_field :category %>
  </div>

  <div>
    <%= f.label :possible_issue_id, "Possible Issue" %><br>
    <%= f.collection_select :possible_issue_id, PossibleIssue.all, :id, :name, include_blank: true %>
  </div>

  <div>
    <%= f.submit %>
  </div>
<% end %>